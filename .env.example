# ============================================
# Algo Bot — Environment Variables (TEMPLATE)
# ============================================
# Copy to .env and fill in real values.
# NEVER commit .env to git.

# --- Mode ---
# paper/demo → simulated fills in data/paper/.  live → Kite + state in data/live/
ALGO_MODE=paper              # paper | demo | live

# --- Broker: Zerodha Kite Connect ---
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# --- Broker: Upstox (free alternative) ---
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=

# --- Broker: Angel One SmartAPI (free alternative) ---
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# --- News / Sentiment ---
NEWSAPI_KEY=
HUGGINGFACE_TOKEN=

# --- LLM (optional, for sentiment curation & Feynman) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Telegram alerts ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Database ---
DATABASE_URL=sqlite:///data/algobot.db

# --- Misc ---
TZ=Asia/Kolkata
LOG_LEVEL=INFO
